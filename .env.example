#DATABASE_URL=postgresql://semsearch:semsearch@localhost:5432/semsearch
#DATABASE_POOL_MAX_SIZE=40
LOG_LEVEL=INFO

# Credentials for the bundled Postgres; compose derives the containers'
# DATABASE_URL from these. Keep the password URL-safe (letters and digits).
#POSTGRES_USER=semsearch
#POSTGRES_PASSWORD=semsearch
#POSTGRES_DB=semsearch

# Where the bundled Postgres stores its data. Unset uses a managed named
# volume. Set to an absolute host path (ideally NVMe, mounted noatime) to keep
# the database on a chosen disk, e.g. PGDATA_DIR=/mnt/nvme/semsearch-pg
#PGDATA_DIR=

# Embedding API
EMBEDDING_API_BASE=https://openrouter.ai/api/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=qwen/qwen3-embedding-4b
EMBEDDING_DIM=2560
EMBEDDING_BATCH_SIZE=32
# HuggingFace repo and commit for the tokenizer
EMBEDDING_TOKENIZER=Qwen/Qwen3-Embedding-4B
EMBEDDING_TOKENIZER_REVISION=5cf2132abc99cad020ac570b19d031efec650f2b

QUERY_INSTRUCTION=Given search query, retrieve relevant passages

#CHUNK_TOKENS=384
#CHUNK_TOKEN_OVERLAP=32

#FETCH_DELAY_SECONDS=2.0
#FETCH_TIMEOUT_SECONDS=20.0
#FETCH_CONCURRENCY=16
#FETCH_IMPERSONATE=chrome
#SITE_POLL_INTERVAL_SECONDS=43200
#SITE_POLL_CONCURRENCY=16
#INGEST_CONCURRENCY=8
#HISTORY_POST_LIMIT=2000
